        {
          "title": "角的分类",
          "kps": [
            "锐角<90°<钝角<180°，直角=90°，平角=180°，周角=360°",
            "1周角=2平角=4直角"
          ],
          "concepts": [
            "锐角",
            "直角",
            "钝角",
            "平角",
            "周角"
          ],
          "difficulty": "基础",
          "weight": "高"
        },
        {
          "title": "画角",
          "kps": [
            "用量角器画指定度数：射线→中心对齐→找刻度→连线",
            "三角尺画30°、45°、60°、90°特殊角"
          ],
          "concepts": [
            "画角"
          ],
          "difficulty": "中等",
          "weight": "中"
        }
      ]
    },
    {
