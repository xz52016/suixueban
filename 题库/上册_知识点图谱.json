          "concepts": [
            "平行",
            "垂直",
            "距离"
          ],
          "difficulty": "中等",
          "weight": "高"
        },
        {
          "title": "平行四边形",
          "kps": [
            "两组对边分别平行且相等，对角相等",
            "不稳定性（容易变形）",
            "底和高的概念"
          ],
          "concepts": [
            "平行四边形",
            "底",
            "高"
          ],
          "difficulty": "中等",
          "weight": "高"
        },
        {
          "title": "梯形",
          "kps": [
