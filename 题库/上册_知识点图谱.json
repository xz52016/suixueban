          "concepts": [
            "四舍试商",
            "五入试商",
            "调商",
            "验算"
          ],
          "difficulty": "较难",
          "weight": "高"
        },
        {
          "title": "商的变化规律",
          "kps": [
            "除数不变，被除数乘几商乘几",
            "被除数不变，除数乘几商反而除以几",
            "被除数和除数同时乘/除以相同非0数，商不变"
          ],
          "concepts": [
            "商的变化",
            "商不变"
