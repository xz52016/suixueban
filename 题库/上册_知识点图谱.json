  "sections": [
    {
      "id": 1,
      "title": "大数的认识",
      "description": "认识万以上的数，掌握计数单位、数位、数级，能读写大数，会比较大小，会改写和求近似数，认识计算器",
      "subsections": [
        {
          "title": "亿以内数的认识",
          "kps": [
            "计数单位：个、十、百、千、万、十万、百万、千万、亿",
            "每相邻两个计数单位间的进率是10",
            "数位：个位~千万位，建立数位顺序表",
            "数级：个级、万级、亿级，每4个数位一级"
          ],
          "concepts": [
            "计数单位",
            "数位",
            "数级",
            "十进制"
          ],
          "difficulty": "基础",
          "weight": "高"
        },
        {
          "title": "亿以内数的读法",
          "kps": [
            "先读万级再读个级，万级加万字",
            "每级末尾0不读，中间连续几个0只读一个"
          ],
          "concepts": [
            "分级读法",
            "0的读法"
          ],
          "difficulty": "基础",
          "weight": "高"
        },
        {
          "title": "亿以内数的写法",
          "kps": [
            "先写万级再写个级",
            "哪一位上一个单位也没有就写0占位"
          ],
          "concepts": [
            "分级写法",
            "0占位"
          ],
          "difficulty": "基础",
          "weight": "高"
        },
        {
          "title": "比较数的大小",
          "kps": [
            "位数不同则位数多的数大",
            "位数相同则从高位逐位比"
          ],
          "concepts": [
            "比较法则"
          ],
          "difficulty": "基础",
          "weight": "中"
        },
        {
          "title": "数的改写",
          "kps": [
            "整万数去掉末尾4个0加万字",
            "整亿数去掉末尾8个0加亿字"
          ],
          "concepts": [
            "改写方法"
          ],
          "difficulty": "基础",
          "weight": "中"
        },
        {
          "title": "近似数（四舍五入）",
          "kps": [
            "省略万位后的尾数：看千位四舍五入",
            "省略亿位后的尾数：看千万位四舍五入",
            "准确数与近似数的区别"
          ],
          "concepts": [
            "四舍五入",
            "近似数"
          ],
          "difficulty": "中等",
          "weight": "高"
        },
        {
          "title": "亿以上数的认识",
          "kps": [
            "亿以上数的读写方法同亿以内数",
            "改写和求近似数方法同上"
          ],
          "concepts": [
            "亿以上数"
          ],
          "difficulty": "中等",
          "weight": "中"
        },
        {
          "title": "计算器的认识和使用",
          "kps": [
            "ON/C、OFF、数字键、运算键、等号键",
            "用计算器进行大数运算和探索规律"
          ],
          "concepts": [
            "计算器"
          ],
          "difficulty": "基础",
          "weight": "低"
        }
      ]
