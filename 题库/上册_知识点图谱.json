    {
      "id": 3,
      "title": "角的度量",
      "description": "认识线段射线直线，理解角，会度量、分类和画角",
      "subsections": [
        {
          "title": "线段、射线、直线",
          "kps": [
            "线段：2端点，可度量；射线：1端点，无限长；直线：0端点，无限长",
            "过一点无数条直线，过两点一条直线"
          ],
          "concepts": [
            "线段",
            "射线",
            "直线"
          ],
          "difficulty": "基础",
          "weight": "中"
        },
        {
          "title": "角的认识和度量",
          "kps": [
            "角：由一点引出两条射线，角的大小与两边叉开程度有关",
            "量角器使用：中心对顶点、0刻度对一边、读另一边刻度",
            "度量单位：度（°）"
          ],
          "concepts": [
            "角",
            "量角器"
          ],
          "difficulty": "基础",
          "weight": "高"
