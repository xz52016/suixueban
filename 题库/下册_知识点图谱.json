    {
      "id": 1,
      "title": "四则运算",
      "description": "理解加减乘除的意义和各部分间的关系，掌握四则混合运算顺序，认识0的运算特性",
      "subsections": [
        {
          "title": "加、减法的意义",
          "kps": [
            "加法：把两个数合并成一个数的运算",
            "减法：已知和与一个加数求另一个加数",
            "和=加数+加数，加数=和-另一个加数",
            "减法是加法的逆运算"
          ],
          "concepts": [
            "加法",
            "减法",
            "逆运算"
          ],
          "diff": "基础",
          "weight": "高"
        },
        {
          "title": "乘、除法的意义",
          "kps": [
            "乘法：求几个相同加数的和的简便运算",
            "除法：已知积与一个因数求另一个因数",
            "积=因数×因数，因数=积÷另一个因数",
            "除法是乘法的逆运算",
            "有余数除法：被除数=商×除数+余数"
          ],
          "concepts": [
            "乘法",
            "除法",
            "因数",
            "积"
          ],
          "diff": "基础",
          "weight": "高"
        },
        {
          "title": "0的运算特性",
          "kps": [
            "一个数+0=原数，一个数-0=原数",
            "被减数=减数时差=0",
            "一个数×0=0，0÷非0的数=0",
            "0不能作除数"
          ],
          "concepts": [
            "0的运算"
          ],
          "diff": "基础",
          "weight": "中"
        },
        {
          "title": "四则混合运算",
          "kps": [
            "没有括号：先乘除后加减",
            "有括号：先算括号里面",
            "同级运算从左到右",
            "三步混合运算的应用"
          ],
          "concepts": [
            "运算顺序",
            "括号"
          ],
          "diff": "中等",
          "weight": "高"
        }
      ]
    },
