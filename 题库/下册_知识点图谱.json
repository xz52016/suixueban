    {
      "id": 3,
      "title": "运算律",
      "description": "掌握加法交换律、结合律、乘法交换律、结合律、分配律，能运用运算律进行简便计算",
      "subsections": [
        {
          "title": "加法运算律",
          "kps": [
            "加法交换律：a+b=b+a",
            "加法结合律：(a+b)+c=a+(b+c)",
            "运用加法运算律简便计算"
          ],
          "concepts": [
            "交换律",
            "结合律"
          ],
          "diff": "基础",
          "weight": "高"
        },
        {
          "title": "乘法运算律",
          "kps": [
            "乘法交换律：a×b=b×a",
            "乘法结合律：(a×b)×c=a×(b×c)",
            "乘法分配律：(a+b)×c=a×c+b×c或a×(b+c)=a×b+a×c"
          ],
          "concepts": [
            "交换律",
            "结合律",
            "分配律"
          ],
          "diff": "中等",
          "weight": "高"
        },
        {
          "title": "简便计算综合",
          "kps": [
            "连减：a-b-c=a-(b+c)",
            "连除：a÷b÷c=a÷(b×c)",
            "凑整思想（如25×4=100，125×8=1000）",
            "拆分法（如102×35=100×35+2×35）"
          ],
          "concepts": [
            "简便计算",
            "凑整"
          ],
          "diff": "中等",
          "weight": "高"
        }
      ]
